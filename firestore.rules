rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - mobileNumber: string (optional)
    //   - union: string (optional)
    //   - upazila: string (required, fixed: 'Sandwip')
    //   - district: string (required, fixed: 'Chittagong')
    //   - role: string (required, ['user', 'admin'])
    //
    // Collection: transports
    // Fields: name, route, time, price, status
    //
    // Collection: emergencyServices
    // Fields: name, category, contactNumber, location, officerName
    //
    // Collection: marketPrices
    // Fields: productName, priceRange, unit, imageUrl, updatedAt
    //
    // Collection: jobCirculars
    // Fields: title, company, description, deadline, postedAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "shuvojahedurrahman15@gmail.com" && request.auth.token.email_verified == true) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'role', 'upazila', 'district']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.role in ['user', 'admin'] &&
             data.upazila == 'Sandwip' &&
             data.district == 'Chittagong';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || request.auth.token.email == "shuvojahedurrahman15@gmail.com");
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || (request.auth.token.email == "shuvojahedurrahman15@gmail.com" && request.resource.data.role == 'admin'));
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin() || request.auth.token.email == "shuvojahedurrahman15@gmail.com") && 
                    (isOwner(userId) ? (request.resource.data.role == resource.data.role && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isOnline', 'lastActive', 'displayName', 'photoURL', 'mobileNumber', 'union']))) : true);
      allow delete: if isAdmin() || request.auth.token.email == "shuvojahedurrahman15@gmail.com";
    }

    match /appSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /transports/{transportId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /emergencyServices/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /marketPrices/{priceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /jobCirculars/{jobId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bloodDonors/{donorId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.uid) && request.resource.data.isApproved == false;
      allow update: if isAdmin() || (isOwner(resource.data.uid) && request.resource.data.isApproved == resource.data.isApproved);
      allow delete: if isAdmin() || isOwner(resource.data.uid);
    }

    match /professionals/{profId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.uid) && request.resource.data.isApproved == false;
      allow update: if isAdmin() || (isOwner(resource.data.uid) && request.resource.data.isApproved == resource.data.isApproved);
      allow delete: if isAdmin() || isOwner(resource.data.uid);
    }

    match /galleryItems/{itemId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.uid) && request.resource.data.isApproved == false;
      allow update: if isAdmin() || (isOwner(resource.data.uid) && request.resource.data.isApproved == resource.data.isApproved);
      allow delete: if isAdmin() || isOwner(resource.data.uid);
    }

    match /notifications/{notifId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /adminConfig/{configId} {
      allow read, write: if isAdmin();
    }
  }
}
