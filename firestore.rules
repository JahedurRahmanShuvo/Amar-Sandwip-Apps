rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is the admin (based on your email)
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "shuvojahedurrahman15@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // 1. User Profiles: Only the owner can read/write their own profile.
    // Admin can also read profiles for management.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // 2. Public Information: Everyone can read, but only Admin can write.
    // This includes transport, market prices, emergency services, etc.
    match /transports/{id} { allow read: if true; allow write: if isAdmin(); }
    match /marketPrices/{id} { allow read: if true; allow write: if isAdmin(); }
    match /emergencyServices/{id} { allow read: if true; allow write: if isAdmin(); }
    match /jobCirculars/{id} { allow read: if true; allow write: if isAdmin(); }
    match /appSettings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /notifications/{id} { allow read: if true; allow write: if isAdmin(); }
    match /announcements/{id} { allow read: if true; allow write: if isAdmin(); }
    match /galleryItems/{id} { allow read: if true; allow write: if isAdmin(); }
    match /professionals/{id} { allow read: if true; allow write: if isAdmin(); }
    match /bloodDonors/{id} { allow read: if true; allow write: if isAdmin(); }

    // 3. Admin Config: Only Admin can access
    match /adminConfig/{id} {
      allow read, write: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
